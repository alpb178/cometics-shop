{
  "kind": "collectionType",
  "collectionName": "orders",
  "info": {
    "singularName": "order",
    "pluralName": "orders",
    "displayName": "Order",
    "description": "Pedidos de clientes"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "orderNumber": {
      "type": "uid"
    },
    "user": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user",
      "inversedBy": "orders"
    },
    "items": {
      "type": "component",
      "repeatable": true,
      "component": "order.item"
    },
    "shippingAddress": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::address.address"
    },
    "deliveryMethod": {
      "type": "enumeration",
      "enum": ["delivery", "pickup"],
      "required": true,
      "default": "pickup"
    },
    "subtotal": {
      "type": "decimal",
      "required": true
    },
    "shippingCost": {
      "type": "decimal"
    },
    "total": {
      "type": "decimal",
      "required": true
    },
    "paymentMethod": {
      "type": "enumeration",
      "enum": ["cash", "qr"],
      "required": true
    },
    "paymentProof": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "status": {
      "type": "enumeration",
      "enum": [
        "pending_verification",
        "confirmed",
        "shipped",
        "delivered",
        "cancelled"
      ],
      "required": true,
      "default": "pending_verification"
    },
    "customerNotes": {
      "type": "text"
    },
    "paymentReference": {
      "type": "string",
      "maxLength": 120
    },
    "cancellationReason": {
      "type": "text"
    },
    "destLat": {
      "type": "decimal"
    },
    "destLng": {
      "type": "decimal"
    }
  }
}
