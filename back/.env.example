# ---- Servidor ----
HOST=0.0.0.0
PORT=1337
# URL pública del backend (usada por Strapi para enlaces absolutos / proxy)
PUBLIC_URL=http://localhost:1337
# Origen del front/backoffice permitido por CORS
CLIENT_URL=http://localhost:3000

# ---- Secretos Strapi (genera valores únicos por entorno) ----
APP_KEYS=key1,key2,key3,key4
API_TOKEN_SALT=tu-salt
ADMIN_JWT_SECRET=tu-secreto
JWT_SECRET=tu-secreto
TRANSFER_TOKEN_SALT=tu-salt
PREVIEW_SECRET=tu-secreto-preview

# ---- Base de datos ----
# Por URL (Supabase/Postgres):
DB_CLIENT=postgres
DATABASE_URL=postgresql://usuario:password@host:5432/postgres
DATABASE_SSL=true
DATABASE_SSL_REJECT_UNAUTHORIZED=false
# O por campos sueltos:
# DB_HOST=
# DB_PORT=5432
# DB_NAME=
# DB_USERNAME=
# DB_PASSWORD=

# ---- Cloudinary (subida de imágenes) ----
CLOUDINARY_NAME=
CLOUDINARY_KEY=
CLOUDINARY_SECRET=

# ---- Email / SMTP ----
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=no-reply@irisnatural.com
EMAIL_REPLY_TO=no-reply@irisnatural.com
RESET_PASSWORD_URL=http://localhost:3000/reset-password

# ---- Acceso del backoffice (OBLIGATORIO para el panel admin) ----
# Lista de emails (separados por coma) con permiso de staff. Solo estos usuarios
# pueden ejecutar mutaciones de catálogo/órdenes y entrar al panel.
# Si se deja vacío, ningún usuario podrá operar el panel ni el catálogo.
# Alternativa: asignar a los usuarios un rol de Strapi con type "staff".
STAFF_EMAILS=admin@irisnatural.com

# ---- Seeder de usuario staff por defecto ----
# En el arranque (bootstrap) se crea un usuario staff del backoffice si no existe
# uno con SEED_ADMIN_EMAIL. Es idempotente. Cambia la contraseña por defecto.
# Para que sea staff, su email debe estar en STAFF_EMAILS (arriba).
SEED_ADMIN_EMAIL=admin@irisnatural.com
SEED_ADMIN_PASSWORD=ChangeMe1234!
SEED_ADMIN_USERNAME=admin

# ---- Login con Google (OAuth) para el storefront ----
# Crea credenciales OAuth 2.0 en Google Cloud Console. Como URI de redirección
# autorizado registra: {PUBLIC_URL}/api/connect/google/callback
# Si se dejan vacías, el proveedor Google queda deshabilitado.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
