# URL del backend Strapi (mismo back/ del monorepo)
NEXT_PUBLIC_STRAPI_URL=http://localhost:1337

# Producción (ejemplo):
# NEXT_PUBLIC_STRAPI_URL=https://shop-strapi-cms.onrender.com

# Allowlist opcional de emails con acceso al panel (separados por coma).
# Si está vacío, cualquier usuario válido de Strapi puede entrar.
# STAFF_EMAILS=admin@irisnatural.com,editor@irisnatural.com
