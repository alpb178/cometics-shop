# URL del backend Strapi (mismo back/ del monorepo)
NEXT_PUBLIC_STRAPI_URL=http://localhost:1337

# Producción (ejemplo):
# NEXT_PUBLIC_STRAPI_URL=https://shop-strapi-cms.onrender.com

# Acceso al panel — OBLIGATORIO. Lista de emails (separados por coma) con
# permiso de staff. El login y cada Server Action verifican esta lista (o un rol
# de Strapi con type "staff"). Si se deja vacío y el usuario no tiene rol staff,
# no podrá iniciar sesión ni operar el panel. Debe coincidir con el STAFF_EMAILS
# del backend.
STAFF_EMAILS=admin@irisnatural.com
