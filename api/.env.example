# Puerto de la API (front usa 3000, backoffice 3001, Strapi 1337)
API_PORT=4000

# Conexión a la base de datos de Supabase (la misma que usa Strapi en back/)
DATABASE_URL=postgresql://user:password@host:5432/postgres?sslmode=require

# Orígenes permitidos para CORS, separados por coma
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Debe ser el mismo JWT_SECRET que usa Strapi (back/.env) para que los tokens
# emitidos por Strapi sigan siendo válidos durante la migración
JWT_SECRET=

# Cloudinary (mismos valores que back/.env)
CLOUDINARY_NAME=
CLOUDINARY_KEY=
CLOUDINARY_SECRET=

# Emails de staff (CSV) — misma regla que back/ y backoffice/
STAFF_EMAILS=admin@irisnatural.com

# Google OAuth (mismos valores que back/.env)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# URL pública de esta API (para el callback OAuth) y del storefront
PUBLIC_URL=http://localhost:4000
CLIENT_URL=http://localhost:3000

# SMTP para forgot-password (mismos nombres que back/)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=no-reply@irisnatural.com
