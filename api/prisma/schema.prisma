generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model addresses {
  id                          Int                           @id @default(autoincrement())
  document_id                 String?                       @db.VarChar(255)
  full_name                   String?                       @db.VarChar(255)
  phone                       String?                       @db.VarChar(255)
  line_1                      String?                       @db.VarChar(255)
  line_2                      String?                       @db.VarChar(255)
  city                        String?                       @db.VarChar(255)
  department                  String?                       @db.VarChar(255)
  notes                       String?
  is_default                  Boolean?
  created_at                  DateTime?                     @db.Timestamp(6)
  updated_at                  DateTime?                     @db.Timestamp(6)
  published_at                DateTime?                     @db.Timestamp(6)
  created_by_id               Int?
  updated_by_id               Int?
  locale                      String?                       @db.VarChar(255)
  ci                          String?                       @db.VarChar(255)
  addresses_user_lnk          addresses_user_lnk[]
  orders_shipping_address_lnk orders_shipping_address_lnk[]

  @@index([document_id, locale, published_at], map: "addresses_documents_idx")
  @@index([created_by_id], map: "addresses_created_by_id_fk_idx")
  @@index([updated_by_id], map: "addresses_updated_by_id_fk_idx")
}

model addresses_user_lnk {
  id          Int        @id @default(autoincrement())
  address_id  Int?
  user_id     Int?
  address_ord Float?
  addresses   addresses? @relation(fields: [address_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "addresses_user_lnk_fk")
  up_users    up_users?  @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "addresses_user_lnk_ifk")

  @@unique([address_id, user_id], map: "addresses_user_lnk_uq")
  @@index([address_ord], map: "addresses_user_lnk_oifk")
  @@index([address_id], map: "addresses_user_lnk_fk_idx")
  @@index([user_id], map: "addresses_user_lnk_ifk_idx")
}

model categories {
  id                      Int                       @id @default(autoincrement())
  document_id             String?                   @db.VarChar(255)
  name                    String?                   @db.VarChar(255)
  created_at              DateTime?                 @db.Timestamp(6)
  updated_at              DateTime?                 @db.Timestamp(6)
  published_at            DateTime?                 @db.Timestamp(6)
  created_by_id           Int?
  updated_by_id           Int?
  locale                  String?                   @db.VarChar(255)
  products_categories_lnk products_categories_lnk[]

  @@index([document_id])
  @@index([document_id, locale, published_at])
  @@index([document_id, locale, published_at], map: "categories_documents_idx")
  @@index([created_by_id], map: "categories_created_by_id_fk_idx")
  @@index([updated_by_id], map: "categories_updated_by_id_fk_idx")
}

model components_order_items {
  id         Int      @id @default(autoincrement())
  product_id Int?
  name       String?  @db.VarChar(255)
  slug       String?  @db.VarChar(255)
  price      Decimal? @db.Decimal(10, 2)
  quantity   Int?
  image_url  String?  @db.VarChar(255)
}

model components_shared_links {
  id     Int     @id @default(autoincrement())
  text   String? @db.VarChar(255)
  url    String? @db.VarChar(255)
  target String? @db.VarChar(255)
}

model faqs {
  id            Int       @id @default(autoincrement())
  document_id   String?   @db.VarChar(255)
  question      String?
  answer        String?
  created_at    DateTime? @db.Timestamp(6)
  updated_at    DateTime? @db.Timestamp(6)
  published_at  DateTime? @db.Timestamp(6)
  created_by_id Int?
  updated_by_id Int?
  locale        String?   @db.VarChar(255)

  @@index([document_id])
  @@index([document_id, locale, published_at])
  @@index([document_id, locale, published_at], map: "faqs_documents_idx")
  @@index([created_by_id], map: "faqs_created_by_id_fk_idx")
  @@index([updated_by_id], map: "faqs_updated_by_id_fk_idx")
}

model files {
  id                Int                 @id @default(autoincrement())
  document_id       String?             @db.VarChar(255)
  name              String?             @db.VarChar(255)
  alternative_text  String?             @db.VarChar(255)
  caption           String?             @db.VarChar(255)
  width             Int?
  height            Int?
  formats           Json?
  hash              String?             @db.VarChar(255)
  ext               String?             @db.VarChar(255)
  mime              String?             @db.VarChar(255)
  size              Decimal?            @db.Decimal(10, 2)
  url               String?             @db.VarChar(255)
  preview_url       String?             @db.VarChar(255)
  provider          String?             @db.VarChar(255)
  provider_metadata Json?
  folder_path       String?             @db.VarChar(255)
  created_at        DateTime?           @db.Timestamp(6)
  updated_at        DateTime?           @db.Timestamp(6)
  published_at      DateTime?           @db.Timestamp(6)
  created_by_id     Int?
  updated_by_id     Int?
  locale            String?             @db.VarChar(255)
  files_related_mph files_related_mph[]

  @@index([document_id])
  @@index([document_id, locale, published_at])
  @@index([document_id, locale, published_at], map: "files_documents_idx")
  @@index([created_at], map: "upload_files_created_at_index")
  @@index([ext], map: "upload_files_ext_index")
  @@index([folder_path], map: "upload_files_folder_path_index")
  @@index([name], map: "upload_files_name_index")
  @@index([size], map: "upload_files_size_index")
  @@index([updated_at], map: "upload_files_updated_at_index")
  @@index([created_by_id], map: "files_created_by_id_fk_idx")
  @@index([updated_by_id], map: "files_updated_by_id_fk_idx")
}

model files_related_mph {
  id           Int     @id @default(autoincrement())
  file_id      Int?
  related_id   Int?
  related_type String? @db.VarChar(255)
  field        String? @db.VarChar(255)
  order        Float?
  files        files?  @relation(fields: [file_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "files_related_mph_fk")

  @@index([related_id], map: "files_related_mph_idix")
  @@index([order], map: "files_related_mph_oidx")
  @@index([file_id], map: "files_related_mph_fk_idx")
}

model logos {
  id            Int       @id @default(autoincrement())
  document_id   String?   @db.VarChar(255)
  company       String?   @db.VarChar(255)
  created_at    DateTime? @db.Timestamp(6)
  updated_at    DateTime? @db.Timestamp(6)
  published_at  DateTime? @db.Timestamp(6)
  created_by_id Int?
  updated_by_id Int?
  locale        String?   @db.VarChar(255)

  @@index([document_id, locale, published_at], map: "logos_documents_idx")
  @@index([created_by_id], map: "logos_created_by_id_fk_idx")
  @@index([updated_by_id], map: "logos_updated_by_id_fk_idx")
}

model logs {
  id            Int       @id @default(autoincrement())
  document_id   String?   @db.VarChar(255)
  time          String?   @db.VarChar(255)
  product       String?   @db.VarChar(255)
  description   String?
  created_at    DateTime? @db.Timestamp(6)
  updated_at    DateTime? @db.Timestamp(6)
  published_at  DateTime? @db.Timestamp(6)
  created_by_id Int?
  updated_by_id Int?
  locale        String?   @db.VarChar(255)

  @@index([document_id, locale, published_at], map: "logs_documents_idx")
  @@index([created_by_id], map: "logs_created_by_id_fk_idx")
  @@index([updated_by_id], map: "logs_updated_by_id_fk_idx")
}

model orders {
  id                          Int                           @id @default(autoincrement())
  document_id                 String?                       @db.VarChar(255)
  order_number                String?                       @db.VarChar(255)
  delivery_method             String?                       @db.VarChar(255)
  subtotal                    Decimal?                      @db.Decimal(10, 2)
  shipping_cost               Decimal?                      @db.Decimal(10, 2)
  total                       Decimal?                      @db.Decimal(10, 2)
  payment_method              String?                       @db.VarChar(255)
  status                      String?                       @db.VarChar(255)
  customer_notes              String?
  created_at                  DateTime?                     @db.Timestamp(6)
  updated_at                  DateTime?                     @db.Timestamp(6)
  published_at                DateTime?                     @db.Timestamp(6)
  created_by_id               Int?
  updated_by_id               Int?
  locale                      String?                       @db.VarChar(255)
  payment_reference           String?                       @db.VarChar(255)
  cancellation_reason         String?
  dest_lat                    Decimal?                      @db.Decimal(10, 2)
  dest_lng                    Decimal?                      @db.Decimal(10, 2)
  orders_cmps                 orders_cmps[]
  orders_shipping_address_lnk orders_shipping_address_lnk[]
  orders_user_lnk             orders_user_lnk[]

  @@index([document_id, locale, published_at], map: "orders_documents_idx")
  @@index([created_by_id], map: "orders_created_by_id_fk_idx")
  @@index([updated_by_id], map: "orders_updated_by_id_fk_idx")
}

model orders_cmps {
  id             Int     @id @default(autoincrement())
  entity_id      Int?
  cmp_id         Int?
  component_type String? @db.VarChar(255)
  field          String? @db.VarChar(255)
  order          Float?
  orders         orders? @relation(fields: [entity_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "orders_entity_fk")

  @@unique([entity_id, cmp_id, field, component_type], map: "orders_uq")
  @@index([component_type], map: "orders_component_type_idx")
  @@index([field], map: "orders_field_idx")
  @@index([entity_id], map: "orders_entity_fk_idx")
}

model orders_shipping_address_lnk {
  id         Int        @id @default(autoincrement())
  order_id   Int?
  address_id Int?
  orders     orders?    @relation(fields: [order_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "orders_shipping_address_lnk_fk")
  addresses  addresses? @relation(fields: [address_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "orders_shipping_address_lnk_ifk")

  @@unique([order_id, address_id], map: "orders_shipping_address_lnk_uq")
  @@index([order_id], map: "orders_shipping_address_lnk_fk_idx")
  @@index([address_id], map: "orders_shipping_address_lnk_ifk_idx")
}

model orders_user_lnk {
  id        Int       @id @default(autoincrement())
  order_id  Int?
  user_id   Int?
  order_ord Float?
  orders    orders?   @relation(fields: [order_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "orders_user_lnk_fk")
  up_users  up_users? @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "orders_user_lnk_ifk")

  @@unique([order_id, user_id], map: "orders_user_lnk_uq")
  @@index([order_ord], map: "orders_user_lnk_oifk")
  @@index([order_id], map: "orders_user_lnk_fk_idx")
  @@index([user_id], map: "orders_user_lnk_ifk_idx")
}

model page_visits {
  id            Int       @id @default(autoincrement())
  document_id   String?   @db.VarChar(255)
  path          String?   @db.VarChar(255)
  referrer      String?   @db.VarChar(255)
  session_id    String?   @db.VarChar(255)
  user_agent    String?
  created_at    DateTime? @db.Timestamp(6)
  updated_at    DateTime? @db.Timestamp(6)
  published_at  DateTime? @db.Timestamp(6)
  created_by_id Int?
  updated_by_id Int?
  locale        String?   @db.VarChar(255)

  @@index([document_id, locale, published_at], map: "page_visits_documents_idx")
  @@index([created_by_id], map: "page_visits_created_by_id_fk_idx")
  @@index([updated_by_id], map: "page_visits_updated_by_id_fk_idx")
}

model payment_infos {
  id             Int       @id @default(autoincrement())
  document_id    String?   @db.VarChar(255)
  bank_name      String?   @db.VarChar(255)
  account_number String?   @db.VarChar(255)
  account_name   String?   @db.VarChar(255)
  account_type   String?   @db.VarChar(255)
  ci             String?   @db.VarChar(255)
  instructions   String?
  created_at     DateTime? @db.Timestamp(6)
  updated_at     DateTime? @db.Timestamp(6)
  published_at   DateTime? @db.Timestamp(6)
  created_by_id  Int?
  updated_by_id  Int?
  locale         String?   @db.VarChar(255)

  @@index([document_id, locale, published_at], map: "payment_infos_documents_idx")
  @@index([created_by_id], map: "payment_infos_created_by_id_fk_idx")
  @@index([updated_by_id], map: "payment_infos_updated_by_id_fk_idx")
}

model pricing_settings {
  id                     Int       @id @default(autoincrement())
  document_id            String?   @db.VarChar(255)
  markup_percent         Decimal?  @db.Decimal(10, 2)
  province_shipping_cost Decimal?  @db.Decimal(10, 2)
  sc_center_lat          Decimal?  @db.Decimal(10, 2)
  sc_center_lng          Decimal?  @db.Decimal(10, 2)
  sc_radius_km           Decimal?  @db.Decimal(10, 2)
  created_at             DateTime? @db.Timestamp(6)
  updated_at             DateTime? @db.Timestamp(6)
  published_at           DateTime? @db.Timestamp(6)
  created_by_id          Int?
  updated_by_id          Int?
  locale                 String?   @db.VarChar(255)

  @@index([document_id, locale, published_at], map: "pricing_settings_documents_idx")
  @@index([created_by_id], map: "pricing_settings_created_by_id_fk_idx")
  @@index([updated_by_id], map: "pricing_settings_updated_by_id_fk_idx")
}

model products {
  id                      Int                       @id @default(autoincrement())
  document_id             String?                   @db.VarChar(255)
  name                    String?                   @db.VarChar(255)
  price                   Int?
  slug                    String?                   @db.VarChar(255)
  currency                String?                   @db.VarChar(255)
  description             String?
  created_at              DateTime?                 @db.Timestamp(6)
  updated_at              DateTime?                 @db.Timestamp(6)
  published_at            DateTime?                 @db.Timestamp(6)
  created_by_id           Int?
  updated_by_id           Int?
  locale                  String?                   @db.VarChar(255)
  visible                 Boolean?                  @default(true)
  discount                Int?
  products_categories_lnk products_categories_lnk[]

  @@index([document_id])
  @@index([document_id, locale, published_at])
  @@index([document_id, locale, published_at], map: "products_documents_idx")
  @@index([created_by_id], map: "products_created_by_id_fk_idx")
  @@index([updated_by_id], map: "products_updated_by_id_fk_idx")
}

model products_categories_lnk {
  id          Int         @id @default(autoincrement())
  product_id  Int?
  category_id Int?
  products    products?   @relation(fields: [product_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "products_categories_lnk_fk")
  categories  categories? @relation(fields: [category_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "products_categories_lnk_ifk")

  @@unique([product_id, category_id], map: "products_categories_lnk_uq")
  @@index([product_id], map: "products_categories_lnk_fk_idx")
  @@index([category_id], map: "products_categories_lnk_ifk_idx")
}

model social_networks {
  id                   Int                    @id @default(autoincrement())
  document_id          String?                @db.VarChar(255)
  alias                String?                @db.VarChar(255)
  name                 String?                @db.VarChar(255)
  created_at           DateTime?              @db.Timestamp(6)
  updated_at           DateTime?              @db.Timestamp(6)
  published_at         DateTime?              @db.Timestamp(6)
  created_by_id        Int?
  updated_by_id        Int?
  locale               String?                @db.VarChar(255)
  social_networks_cmps social_networks_cmps[]

  @@index([document_id])
  @@index([document_id, locale, published_at])
  @@index([document_id, locale, published_at], map: "social_networks_documents_idx")
  @@index([created_by_id], map: "social_networks_created_by_id_fk_idx")
  @@index([updated_by_id], map: "social_networks_updated_by_id_fk_idx")
}

model social_networks_cmps {
  id              Int              @id @default(autoincrement())
  entity_id       Int?
  cmp_id          Int?
  component_type  String?          @db.VarChar(255)
  field           String?          @db.VarChar(255)
  order           Float?
  social_networks social_networks? @relation(fields: [entity_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "social_networks_entity_fk")

  @@unique([entity_id, cmp_id, field, component_type], map: "social_networks_uq")
  @@index([component_type], map: "social_networks_component_type_idx")
  @@index([field], map: "social_networks_field_idx")
  @@index([entity_id], map: "social_networks_entity_fk_idx")
}

model store_events {
  id            Int       @id @default(autoincrement())
  document_id   String?   @db.VarChar(255)
  type          String?   @db.VarChar(255)
  label         String?   @db.VarChar(255)
  product_slug  String?   @db.VarChar(255)
  quantity      Int?
  path          String?   @db.VarChar(255)
  session_id    String?   @db.VarChar(255)
  created_at    DateTime? @db.Timestamp(6)
  updated_at    DateTime? @db.Timestamp(6)
  published_at  DateTime? @db.Timestamp(6)
  created_by_id Int?
  updated_by_id Int?
  locale        String?   @db.VarChar(255)

  @@index([document_id, locale, published_at], map: "store_events_documents_idx")
  @@index([created_by_id], map: "store_events_created_by_id_fk_idx")
  @@index([updated_by_id], map: "store_events_updated_by_id_fk_idx")
}

model up_roles {
  id                Int                 @id @default(autoincrement())
  document_id       String?             @db.VarChar(255)
  name              String?             @db.VarChar(255)
  description       String?             @db.VarChar(255)
  type              String?             @db.VarChar(255)
  created_at        DateTime?           @db.Timestamp(6)
  updated_at        DateTime?           @db.Timestamp(6)
  published_at      DateTime?           @db.Timestamp(6)
  created_by_id     Int?
  updated_by_id     Int?
  locale            String?             @db.VarChar(255)
  up_users_role_lnk up_users_role_lnk[]

  @@index([document_id])
  @@index([document_id, locale, published_at])
  @@index([document_id, locale, published_at], map: "up_roles_documents_idx")
  @@index([created_by_id], map: "up_roles_created_by_id_fk_idx")
  @@index([updated_by_id], map: "up_roles_updated_by_id_fk_idx")
}

model up_users {
  id                   Int                  @id @default(autoincrement())
  document_id          String?              @db.VarChar(255)
  username             String?              @db.VarChar(255)
  email                String?              @db.VarChar(255)
  provider             String?              @db.VarChar(255)
  password             String?              @db.VarChar(255)
  reset_password_token String?              @db.VarChar(255)
  confirmation_token   String?              @db.VarChar(255)
  confirmed            Boolean?
  blocked              Boolean?
  created_at           DateTime?            @db.Timestamp(6)
  updated_at           DateTime?            @db.Timestamp(6)
  published_at         DateTime?            @db.Timestamp(6)
  created_by_id        Int?
  updated_by_id        Int?
  locale               String?              @db.VarChar(255)
  first_name           String?              @db.VarChar(255)
  last_name            String?              @db.VarChar(255)
  phone                String?              @db.VarChar(255)
  addresses_user_lnk   addresses_user_lnk[]
  orders_user_lnk      orders_user_lnk[]
  up_users_role_lnk    up_users_role_lnk[]

  @@index([document_id])
  @@index([document_id, locale, published_at])
  @@index([document_id, locale, published_at], map: "up_users_documents_idx")
  @@index([created_by_id], map: "up_users_created_by_id_fk_idx")
  @@index([updated_by_id], map: "up_users_updated_by_id_fk_idx")
}

model up_users_role_lnk {
  id       Int       @id @default(autoincrement())
  user_id  Int?
  role_id  Int?
  user_ord Float?
  up_users up_users? @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "up_users_role_lnk_fk")
  up_roles up_roles? @relation(fields: [role_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "up_users_role_lnk_ifk")

  @@unique([user_id, role_id], map: "up_users_role_lnk_uq")
  @@index([user_ord], map: "up_users_role_lnk_oifk")
  @@index([user_id], map: "up_users_role_lnk_fk_idx")
  @@index([role_id], map: "up_users_role_lnk_ifk_idx")
}
