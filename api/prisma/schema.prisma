generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model addresses {
  id                                               Int                           @id @default(autoincrement())
  document_id                                      String?                       @db.VarChar(255)
  full_name                                        String?                       @db.VarChar(255)
  phone                                            String?                       @db.VarChar(255)
  line_1                                           String?                       @db.VarChar(255)
  line_2                                           String?                       @db.VarChar(255)
  city                                             String?                       @db.VarChar(255)
  department                                       String?                       @db.VarChar(255)
  notes                                            String?
  is_default                                       Boolean?
  created_at                                       DateTime?                     @db.Timestamp(6)
  updated_at                                       DateTime?                     @db.Timestamp(6)
  published_at                                     DateTime?                     @db.Timestamp(6)
  created_by_id                                    Int?
  updated_by_id                                    Int?
  locale                                           String?                       @db.VarChar(255)
  ci                                               String?                       @db.VarChar(255)
  admin_users_addresses_created_by_idToadmin_users admin_users?                  @relation("addresses_created_by_idToadmin_users", fields: [created_by_id], references: [id], onUpdate: NoAction, map: "addresses_created_by_id_fk")
  admin_users_addresses_updated_by_idToadmin_users admin_users?                  @relation("addresses_updated_by_idToadmin_users", fields: [updated_by_id], references: [id], onUpdate: NoAction, map: "addresses_updated_by_id_fk")
  addresses_user_lnk                               addresses_user_lnk[]
  orders_shipping_address_lnk                      orders_shipping_address_lnk[]

  @@index([created_by_id], map: "addresses_created_by_id_fk_idx")
  @@index([document_id, locale, published_at], map: "addresses_documents_idx")
  @@index([updated_by_id], map: "addresses_updated_by_id_fk_idx")
}

model addresses_user_lnk {
  id          Int        @id @default(autoincrement())
  address_id  Int?
  user_id     Int?
  address_ord Float?
  addresses   addresses? @relation(fields: [address_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "addresses_user_lnk_fk")
  up_users    up_users?  @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "addresses_user_lnk_ifk")

  @@unique([address_id, user_id], map: "addresses_user_lnk_uq")
  @@index([address_id], map: "addresses_user_lnk_fk_idx")
  @@index([user_id], map: "addresses_user_lnk_ifk_idx")
  @@index([address_ord], map: "addresses_user_lnk_oifk")
}

model admin_permissions {
  id                                                       Int                                       @id @default(autoincrement())
  document_id                                              String?                                   @db.VarChar(255)
  action                                                   String?                                   @db.VarChar(255)
  action_parameters                                        Json?
  subject                                                  String?                                   @db.VarChar(255)
  properties                                               Json?
  conditions                                               Json?
  created_at                                               DateTime?                                 @db.Timestamp(6)
  updated_at                                               DateTime?                                 @db.Timestamp(6)
  published_at                                             DateTime?                                 @db.Timestamp(6)
  created_by_id                                            Int?
  updated_by_id                                            Int?
  locale                                                   String?                                   @db.VarChar(255)
  admin_users_admin_permissions_created_by_idToadmin_users admin_users?                              @relation("admin_permissions_created_by_idToadmin_users", fields: [created_by_id], references: [id], onUpdate: NoAction, map: "admin_permissions_created_by_id_fk")
  admin_users_admin_permissions_updated_by_idToadmin_users admin_users?                              @relation("admin_permissions_updated_by_idToadmin_users", fields: [updated_by_id], references: [id], onUpdate: NoAction, map: "admin_permissions_updated_by_id_fk")
  admin_permissions_role_lnk                               admin_permissions_role_lnk[]
  strapi_workflows_stages_permissions_lnk                  strapi_workflows_stages_permissions_lnk[]

  @@index([created_by_id], map: "admin_permissions_created_by_id_fk_idx")
  @@index([document_id])
  @@index([document_id, locale, published_at])
  @@index([document_id, locale, published_at], map: "admin_permissions_documents_idx")
  @@index([updated_by_id], map: "admin_permissions_updated_by_id_fk_idx")
}

model admin_permissions_role_lnk {
  id                Int                @id @default(autoincrement())
  permission_id     Int?
  role_id           Int?
  permission_ord    Float?
  admin_permissions admin_permissions? @relation(fields: [permission_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "admin_permissions_role_lnk_fk")
  admin_roles       admin_roles?       @relation(fields: [role_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "admin_permissions_role_lnk_ifk")

  @@unique([permission_id, role_id], map: "admin_permissions_role_lnk_uq")
  @@index([permission_id], map: "admin_permissions_role_lnk_fk_idx")
  @@index([role_id], map: "admin_permissions_role_lnk_ifk_idx")
  @@index([permission_ord], map: "admin_permissions_role_lnk_oifk")
}

model admin_roles {
  id                                                 Int                          @id @default(autoincrement())
  document_id                                        String?                      @db.VarChar(255)
